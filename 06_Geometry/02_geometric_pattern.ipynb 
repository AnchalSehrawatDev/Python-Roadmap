      "source": [
        "#Setup the canvas\n",
        "\n",
        "initializeTurtle()\n",
        "bgcolor(\"black\")          # Black background makes colors pop\n",
        "speed(10)                 # Fast drawing speed\n",
        "width(2)                  # Thicker lines\n",
        "\n",
        "# 2. Draw the geometric design\n",
        "# We will repeat a pattern of 4 squares, 10 times (40 squares total)\n",
        "for i in range(10):\n",
        "\n",
        "    #square 1\n",
        "    color(\"white\")\n",
        "    for _ in range(4):\n",
        "        forward(100)\n",
        "        left(90)\n",
        "    left(9) # Turn slightly\n",
        "\n",
        "    # Square 2\n",
        "    color(\"#C5FF96\")\n",
        "    for _ in range(4):\n",
        "        forward(100)\n",
        "        left(90)\n",
        "    left(9) # Turn slightly\n",
        "\n",
        "    # Square 3\n",
        "    color(\"#96FAFF\")\n",
        "    for _ in range(4):\n",
        "        forward(100)\n",
        "        left(90)\n",
        "    left(9) # Turn slightly\n",
        "\n",
        "    # Square 4\n",
        "    color(\"#FFE924\")\n",
        "    for _ in range(4):\n",
        "        forward(100)\n",
        "        left(90)\n",
        "    left(9) # Turn slightly\n",
        "\n",
        "# 3. Move the turtle away when done\n",
        "penup()\n",
        "goto(0, 0)"
      ]
